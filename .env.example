# Anthropic API Key (for Claude 3.5 Sonnet)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# Firecrawl API Key (for article scraping)
FIRECRAWL_API_KEY=fc-xxxxx

# Gmail Configuration (used for both SMTP sending and IMAP listening)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-sending-address@gmail.com
SMTP_PASSWORD=your-gmail-app-password  # Gmail App Password (not your regular password)

# Email Recipients
EMAIL_TO=editor@example.com
EMAIL_CC=reviewer@example.com
